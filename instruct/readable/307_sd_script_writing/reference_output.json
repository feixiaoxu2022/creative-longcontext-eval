        {
          "type": "dialogue",
          "character": "录音中的陆景琛",
          "line": "她挡了我的路，我必须除掉她。"
        },
        {
          "type": "action",
          "description": "陆景琛和林诗雨听到自己的声音，脸色惨白，浑身发抖。"
