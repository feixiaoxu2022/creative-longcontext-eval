        "time": "白天",
        "atmosphere": "震惊、意外"
      },
      "characters": ["沈念", "苏晚棠"],
      "content": [
        {"type": "emotion", "description": "后台里，沈念正在整理文件"},
        {"type": "action", "character": "苏晚棠", "description": "突然出现"},
        {"type": "action", "character": "沈念", "description": "警惕地看着她"},
        {"type": "dialogue", "character": "沈念", "line": "你来做什么？来看我笑话？"},
        {"type": "action", "character": "苏晚棠", "description": "摇摇头"},
        {"type": "dialogue", "character": "苏晚棠", "line": "我想...我想帮你作证"},
        {"type": "action", "character": "沈念", "description": "愣住了"},
        {"type": "dialogue", "character": "沈念", "line": "你？"},
        {"type": "dialogue", "character": "苏晚棠", "line": "沈德忠...他用我母亲的命威胁我"},
        {"type": "dialogue", "character": "苏晚棠", "line": "但我现在不怕了"}
      ]
    },
    {
      "scene_number": 3,
      "scene_header": {
        "location": "记者会现场",
        "time": "白天",
        "atmosphere": "震撼、感动"
      },
      "characters": ["沈念", "苏晚棠", "记者们"],
      "content": [
        {"type": "emotion", "description": "记者会上，苏晚棠走上台"},
        {"type": "dialogue", "character": "苏晚棠", "line": "我是苏晚棠...今天我要说出真相"},
        {"type": "dialogue", "character": "苏晚棠", "line": "三年前，是我配合沈德忠陷害了沈念"},
        {"type": "action", "character": "沈念", "description": "站在一旁，眼眶红了"},
        {"type": "dialogue", "character": "苏晚棠", "line": "我背叛过她...但现在我想赎回自己的灵魂"},
        {"type": "dialogue", "character": "苏晚棠", "line": "沈德忠才是幕后黑手...他有罪"},
        {"type": "action", "character": "沈念", "description": "走上前，拉住苏晚棠的手"},
        {"type": "dialogue", "character": "沈念", "line": "谢谢...谢谢你愿意站出来"},
        {"type": "emotion", "description": "两人相拥而泣，记者们疯狂拍照"}
      ]
