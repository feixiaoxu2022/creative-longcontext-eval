        {"type": "action", "character": "沈念", "description": "走上台，面色冷静"},
        {"type": "dialogue", "character": "沈念", "line": "今天我要揭露沈德忠的真面目"},
        {"type": "dialogue", "character": "沈念", "line": "他不仅害死了我的生父"},
        {"type": "dialogue", "character": "沈念", "line": "还策划了商业犯罪、贿赂、谋杀..."},
        {"type": "action", "character": "记者们", "description": "疯狂地拍照"},
        {"type": "dialogue", "character": "记者", "line": "沈小姐，你有什么证据？"},
        {"type": "dialogue", "character": "沈念", "line": "证据...就在这里"},
        {"type": "action", "character": "沈念", "description": "大屏幕上开始播放证据"}
      ]
    },
    {
      "scene_number": 2,
      "scene_header": {
