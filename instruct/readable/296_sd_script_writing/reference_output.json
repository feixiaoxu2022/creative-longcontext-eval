        {
          "type": "dialogue",
          "character": "张叔叔",
          "line": "没错。这个组织叫'暗网'，专门针对世界各地的正义人士。"
        },
        {
          "type": "dialogue",
          "character": "陆沉",
          "line": "那我们现在该怎么办？"
        },
        {
          "type": "dialogue",
          "character": "张叔叔",
          "line": "他们已经注意到陈野了。"
        },
        {
          "type": "emotion",
          "description": "陈野握紧拳头。"
        },
        {
          "type": "dialogue",
          "character": "陈野",
          "line": "那就让他们来。"
        }
      ]
    },
