  "title": "王牌证据",
  "scenes_detail": [
    {
      "scene_header": {
        "location": "林晚的公司",
        "time": "白天",
        "atmosphere": "紧张思考"
      },
      "characters": ["林晚", "顾深"],
      "content": [
        {
          "type": "action",
          "character": "林晚",
          "text": "林晚坐在公司办公室里，面前放着Mentor的财务漏洞证据。"
        },
        {
          "type": "action",
          "character": "顾深",
          "text": "顾深走进办公室，看到林晚。"
        },
        {
          "type": "dialogue",
          "character": "顾深",
          "text": "林晚，你找到什么了？"
        },
        {
          "type": "action",
          "character": "林晚",
          "text": "林晚抬起头，看向顾深。"
        },
        {
          "type": "dialogue",
          "character": "林晚",
          "text": "顾深，我找到了Mentor的财务漏洞证据。"
        },
        {
          "type": "action",
          "character": "顾深",
          "text": "顾深走到林晚面前。"
        },
        {
          "type": "dialogue",
          "character": "顾深",
          "text": "林晚，这是你的机会。"
        },
        {
          "type": "action",
          "character": "林晚",
          "text": "林晚沉默了一会儿。"
        },
        {
          "type": "dialogue",
          "character": "林晚",
          "text": "顾深，我...我不知道该不该用这个证据。"
        },
        {
          "type": "action",
          "character": "顾深",
          "text": "顾深愣了一下。"
        },
        {
          "type": "dialogue",
          "character": "顾深",
          "text": "林晚，你在犹豫什么？"
        },
        {
          "type": "action",
          "character": "林晚",
          "text": "林晚站起身，走到窗边。"
        },
        {
          "type": "dialogue",
          "character": "林晚",
          "text": "顾深，Mentor是我的老师。我曾经很尊敬她。"
        },
        {
          "type": "action",
          "character": "顾深",
          "text": "顾深走到林晚身边。"
        },
        {
          "type": "dialogue",
          "character": "顾深",
          "text": "林晚，她抛弃了你。她把你当棋子。"
        },
        {
          "type": "action",
          "character": "林晚",
          "text": "林晚沉默了一会儿。"
        },
        {
          "type": "dialogue",
          "character": "林晚",
          "text": "我知道。但是...我还是下不了手。"
        },
        {
          "type": "action",
          "character": "顾深",
          "text": "顾深叹了口气。"
        },
        {
          "type": "dialogue",
          "character": "顾深",
          "text": "林晚，你太善良了。在商场上，善良是弱点。"
        },
        {
          "type": "action",
          "character": "林晚",
          "text": "林晚转身看向顾深。"
        },
        {
          "type": "dialogue",
          "character": "林晚",
          "text": "顾深，你为什么要帮我？"
        },
        {
          "type": "dialogue",
          "character": "顾深",
          "text": "我帮你，是因为我看到了你的潜力。林晚，你想报仇吗？"
        },
        {
          "type": "action",
          "character": "林晚",
          "text": "林晚抬起头，眼中闪过一丝决绝。"
        },
        {
          "type": "dialogue",
          "character": "林晚",
          "text": "想。我一定要报仇。"
        },
        {
          "type": "dialogue",
          "character": "顾深",
          "text": "很好。那我们开始吧。"
        },
        {
          "type": "action",
          "character": "林晚",
          "text": "林晚第一次露出复仇的微笑。"
        },
        {
          "type": "emotion",
          "text": "林晚的眼中燃烧着复仇的火焰。"
        }
      ]
    },
    {
      "scene_header": {
