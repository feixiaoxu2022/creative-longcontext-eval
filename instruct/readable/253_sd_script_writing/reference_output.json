    {
      "scene_header": {
        "location": "Mentor的办公室",
        "time": "白天",
        "atmosphere": "紧张焦虑"
      },
      "characters": ["林晚", "苏雅琴"],
      "content": [
        {
          "type": "action",
          "character": "林晚",
          "text": "林晚走进Mentor的办公室，苏雅琴坐在办公桌后。"
        },
        {
          "type": "dialogue",
          "character": "苏雅琴",
          "text": "林晚，你来了。"
        },
        {
          "type": "action",
          "character": "林晚",
          "text": "林晚走到苏雅琴面前。"
        },
        {
          "type": "dialogue",
          "character": "林晚",
          "text": "Mentor，我来了。"
        },
        {
          "type": "action",
          "character": "苏雅琴",
          "text": "苏雅琴站起身，走到林晚面前。"
        },
        {
          "type": "dialogue",
          "character": "苏雅琴",
          "text": "林晚，你找我有什么事？"
        },
        {
          "type": "action",
          "character": "林晚",
          "text": "林晚从包里拿出一份文件。"
        },
        {
          "type": "dialogue",
          "character": "林晚",
          "text": "Mentor，这是你的财务漏洞证据。"
        },
        {
          "type": "action",
          "character": "苏雅琴",
          "text": "苏雅琴看到文件，脸色一变。"
        },
        {
          "type": "dialogue",
          "character": "苏雅琴",
          "text": "你...你怎么会有这些？"
        },
        {
          "type": "dialogue",
          "character": "林晚",
          "text": "我调查过你的过去。Mentor，你年轻时也被当棋子用过，所以你现在把别人当棋子。"
        },
        {
          "type": "action",
          "character": "苏雅琴",
          "text": "苏雅琴震惊地看着林晚。"
        },
        {
          "type": "dialogue",
          "character": "苏雅琴",
          "text": "你...你怎么知道？"
        },
        {
          "type": "dialogue",
          "character": "林晚",
          "text": "我调查过你的过去。Mentor，你年轻时也被当棋子用过，所以你现在把别人当棋子。"
        },
        {
          "type": "action",
          "character": "林晚",
          "text": "林晚冷笑一声。"
        },
        {
          "type": "dialogue",
          "character": "林晚",
          "text": "Mentor，你以为你能打败我？"
        },
        {
          "type": "action",
          "character": "苏雅琴",
          "text": "苏雅琴愣在原地。"
        },
        {
          "type": "dialogue",
          "character": "苏雅琴",
          "text": "你...你想怎么样？"
        },
        {
          "type": "dialogue",
          "character": "林晚",
          "text": "Mentor，我想怎么样？我想让你知道，你教会了我一切，现在我要用你教我的东西，打败你。"
        },
        {
          "type": "action",
          "character": "苏雅琴",
          "text": "苏雅琴震惊地看着林晚。"
        },
        {
          "type": "dialogue",
          "character": "苏雅琴",
          "text": "林晚，你...你变了。"
        },
        {
          "type": "action",
          "character": "林晚",
          "text": "林晚冷笑一声。"
        },
        {
          "type": "dialogue",
          "character": "林晚",
          "text": "Mentor，我变了。我变得像你一样冷酷。"
        },
        {
          "type": "emotion",
          "text": "林晚在Mentor面前第一次打脸，眼中燃烧着复仇的火焰。"
        }
      ]
    }
