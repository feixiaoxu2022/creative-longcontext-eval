          "text": "想。我一定要报仇。"
        },
        {
          "type": "dialogue",
          "character": "顾深",
          "text": "很好。那我们开始吧。"
        },
        {
          "type": "action",
          "character": "林晚",
          "text": "林晚第一次露出复仇的微笑。"
        },
        {
          "type": "emotion",
          "text": "林晚的眼中燃烧着复仇的火焰。"
        }
