        {"type": "action", "character": "林深", "description": "再次冲向陈默"},
        {"type": "dialogue", "character": "林深", "text": "今天，一切都要结束！"},
        {"type": "action", "character": "陈默", "description": "电击器击中林深肩膀"},
        {"type": "dialogue", "character": "陈默", "text": "结束？我花了二十年，怎么可能让你结束！"},
        {"type": "action", "character": "林深", "description": "忍痛抓住陈默的手臂，两人扭打在一起"},
        {"type": "emotion", "description": "林深逐渐不支，陈默的疯狂赋予他惊人的力量。"},
        {"type": "dialogue", "character": "林深", "description": "喘息", "text": "苏晚！快！"}
      ]
    },
    {
