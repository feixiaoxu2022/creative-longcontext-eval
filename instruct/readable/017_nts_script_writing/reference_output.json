{
  "episode_number": 2,
  "title": "不速之客",
  "scenes": [
    {
      "scene_number": 1,
      "location": "丁家大宅客厅",
      "time_of_day": "黄昏",
      "atmosphere": "尴尬中带着好奇",
      "weather": "夏日黄昏，暖光渐暗",
      "sfx_ambient": "蝉鸣声，远处脚步声",
      "initial_shot": "【全景】客厅中央，纪慎语独自站着，丁汉白翘腿坐在沙发上",
      "characters": ["丁汉白", "纪慎语", "姜廷恩", "丁延寿"],
      "content": [
        {
          "type": "action",
          "text": "【全景】客厅中央，纪慎语独自站着。【中景】丁汉白翘腿坐在沙发上，一脸看电视的悠闲。"
        },
        {
          "type": "action",
          "text": "【跟拍】姜廷恩从外面跑进来，满头大汗。【近景】他眼睛发亮，兴奋地大喊。"
        },
        {
          "type": "dialogue",
          "character": "姜廷恩",
          "emotion": "兴奋",
          "text": "姑父！门口那几只大箱子都是你带回来的啊？！"
        },
        {
          "type": "action",
          "text": "【特写】纪慎语反应最快，猛地回头看向丁延寿。【中景】丁延寿用手掌冲着纪慎语。"
        },
        {
          "type": "dialogue",
          "character": "丁延寿",
          "emotion": "平静",
          "text": "都是慎语的，你们几个年轻力壮的帮忙搬一下。"
        },
        {
          "type": "dialogue",
          "character": "姜漱柳",
          "emotion": "犹豫",
          "text": "搬到——"
        },
        {
          "type": "action",
          "text": "【特写】丁汉白右眼皮跳了两下。【中景】丁延寿语气不容置疑。"
        },
        {
          "type": "dialogue",
          "character": "丁延寿",
          "emotion": "命令",
          "text": "搬汉白院子里，就住正屋隔壁那间。"
        },
        {
          "type": "action",
          "text": "【全景】幸灾乐祸的笑声响起来。【近景】丁汉白一拳砸在丁可愈腰上，眼神无奈又嫌弃。"
        },
        {
          "type": "dialogue",
          "character": "丁汉白",
          "emotion": "无奈",
          "text": "走吧，五师弟。"
        },
        {
          "type": "action",
          "text": "【跟拍】纪慎语带着满鬓汗珠跟丁汉白出屋。【拉镜头】两人背影消失在门口。【淡出】"
        }
      ]
    },
    {
      "scene_number": 2,
      "location": "丁汉白小院",
      "time_of_day": "黄昏",
      "atmosphere": "剑拔弩张的对峙",
      "weather": "夏日傍晚，绿植投下斑驳影子",
      "sfx_ambient": "虫鸣声，箱子拖拽声",
      "initial_shot": "【全景】小院门口，三口大箱子堵在门口，满满当当",
      "characters": ["丁汉白", "纪慎语", "丁可愈", "姜廷恩"],
      "content": [
        {
          "type": "action",
          "text": "【全景】小院门口，三口大箱子堵在门口。【中景】丁可愈插着腰，一脸不满。"
        },
        {
          "type": "dialogue",
          "character": "丁可愈",
          "emotion": "嘲讽",
          "text": "大姑娘出嫁也没这么多东西吧。"
        },
        {
          "type": "action",
          "text": "【特写】丁汉白用鞋尖踢踢箱子。【近景】纪慎语急出声，伸手护住箱子。"
        },
        {
          "type": "dialogue",
          "character": "纪慎语",
          "emotion": "焦急",
          "text": "别动！"
        },
        {
          "type": "action",
          "text": "【特写】兄弟三人微愣，同时觑纪慎语一眼。【中景】丁汉白揣起裤兜，好整以暇地立定。"
        },
        {
          "type": "dialogue",
          "character": "丁汉白",
          "emotion": "冷笑",
          "text": "光我别动？我觉得都别动了，你自己搬吧。"
        },
        {
          "type": "action",
          "text": "【近景】纪慎语蹙着眉一脸难色，语气软下来。【特写】他眼神诚恳。"
        },
        {
          "type": "dialogue",
          "character": "纪慎语",
          "emotion": "道歉",
          "text": "里面的东西不禁磕，我一时着急，师哥别跟我计较。"
        },
        {
          "type": "action",
          "text": "【中景】丁汉白下马威点到为止，招手让丁可愈和姜廷恩搬一口。【跟拍】他和纪慎语合力搬一口。"
        },
        {
          "type": "action",
          "text": "【全景】来回两趟把几口箱子全搬回小院。【中景】姜廷恩擦着汗，看着满屋箱子发愁。"
        },
        {
          "type": "dialogue",
          "character": "姜廷恩",
          "emotion": "发愁",
          "text": "这么大的箱子搬进去怎么放啊？"
        },
        {
          "type": "dialogue",
          "character": "纪慎语",
          "emotion": "试探",
          "text": "靠着墙行吗？"
        },
        {
          "type": "action",
          "text": "【近景】丁汉白拍裤腿蹭的尘土，语气不容商量。【推镜头到特写】他眼神锐利。"
        },
        {
          "type": "dialogue",
          "character": "丁汉白",
          "emotion": "强势",
          "text": "不行。你住这儿，不等于这儿就是你的地盘。"
        },
        {
          "type": "dialogue",
          "character": "丁汉白",
          "emotion": "嫌弃",
          "text": "仨箱子塞进去难看死了，开箱留的留，扔的扔，别想弄一屋破烂儿占地方。"
        },
        {
          "type": "action",
          "text": "【特写】纪慎语脸通红，不知是热的还是气的。【近景】他眼神坚定。"
        },
        {
          "type": "dialogue",
          "character": "纪慎语",
          "emotion": "坚持",
          "text": "我没破烂儿，都有用。"
        },
        {
          "type": "action",
          "text": "【特写】丁汉白挑眉，嘴角勾起一抹玩味的笑。【拉镜头】两人对视，气氛微妙。【淡出】"
        }
      ]
    },
    {
      "scene_number": 3,
      "location": "丁汉白小院",
      "time_of_day": "深夜",
      "atmosphere": "静谧中暗藏秘密",
      "weather": "月夜，柔和透亮的光线",
      "sfx_ambient": "虫鸣声，轻微雕刻声",
      "initial_shot": "【全景】月光下的小院，绿植投下斑驳影子，一间屋子亮着灯",
      "characters": ["丁汉白", "纪慎语"],
      "content": [
        {
          "type": "action",
          "text": "【全景】月光下的小院，一间屋子亮着灯。【跟拍】丁汉白刚洗完澡，穿着背心短裤，路过纪慎语房间。"
        },
        {
          "type": "action",
          "text": "【特写】丁汉白脚步一顿，透过窗户缝隙往里看。【推镜头】窗内，纪慎语正低头雕刻。"
        },
        {
          "type": "action",
          "text": "【特写】纪慎语手中的刻刀在木料上游走，手法娴熟。【近景】他神情专注，完全没注意到窗外有人。"
        },
        {
          "type": "action",
          "text": "【特写】丁汉白眼神微变，从嫌弃转为惊讶。【推镜头到特写】他看清了纪慎语手中的作品。"
        },
        {
          "type": "inner_voice",
          "character": "丁汉白",
          "emotion": "惊讶",
          "text": "这手法……有点东西啊。"
        },
        {
          "type": "action",
          "text": "【中景】丁汉白没有打扰，悄悄退后。【拉镜头】他站在月光下，若有所思地看着那间亮灯的屋子。"
        },
        {
          "type": "action",
          "text": "【特写】丁汉白嘴角勾起一抹意味深长的笑。【全景】月光洒在小院，两间屋子的灯光一明一暗。【画面定格】"
        },
        {
          "type": "sound",
          "text": "BGM：悬疑氛围音乐渐强"
        },
        {
          "type": "effect",
          "text": "【特效】屏幕下方出现字幕：下集预告——试探与认可"
        }
      ]
    }
  ]
}
