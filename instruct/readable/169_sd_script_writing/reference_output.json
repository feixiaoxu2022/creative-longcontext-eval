      "characters": ["陆沉舟", "苏晚"],
      "content": [
        {"type": "action", "character": "陆沉舟", "description": "和苏晚躲在暗处，观察总部情况"},
        {"type": "dialogue", "character": "陆沉舟", "line": "他们把知微带进去了"},
        {"type": "dialogue", "character": "苏晚", "line": "首领不会伤害她。至少现在不会"},
        {"type": "dialogue", "character": "陆沉舟", "line": "为什么？"},
        {"type": "dialogue", "character": "苏晚", "line": "因为首领需要她。至于为什么...我也不确定"},
        {"type": "action", "character": "陆沉舟", "description": "握紧拳头"},
        {"type": "dialogue", "character": "陆沉舟", "line": "不管怎样，我一定要救她出来"},
        {"type": "dialogue", "character": "苏晚", "line": "别急。等她们谈完，我们再见机行事"}
