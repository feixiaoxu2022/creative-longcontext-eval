        {"type": "dialogue", "character": "沈知微", "line": "你就是首领？"},
        {"type": "action", "character": "首领", "description": "缓缓转过身"},
        {"type": "emotion", "description": "沈知微瞳孔骤缩——那张脸，和她一模一样"},
        {"type": "dialogue", "character": "沈知微", "line": "你...你是谁？"},
        {"type": "dialogue", "character": "首领", "line": "我是你。或者说，是上一个时间线的你"},
        {"type": "dialogue", "character": "沈知微", "line": "不可能..."},
        {"type": "dialogue", "character": "首领", "line": "我在自己的时间线失败了。所以我创建了组织，防止其他变量重蹈覆辙"}
      ]
    },
    {
      "scene_number": 3,
