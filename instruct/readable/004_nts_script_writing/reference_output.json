{
  "episode_number": 3,
  "title": "室友争夺战",
  "scenes": [
    {
      "scene_number": 1,
      "location": "小洋楼·二楼女生卧室",
      "time_of_day": "午后",
      "atmosphere": "梦幻甜美，欢乐轻松中夹杂沈央的暗戳戳羡慕",
      "weather": "窗外午后阳光",
      "sfx_ambient": "女生们的惊叹声、脚步声",
      "initial_shot": "【中景】六人走上二楼楼梯，段薇薇走在最前面，兴奋地推开女生卧室的门——",
      "characters": ["沈央", "宿寒英", "杨天驰", "龙女", "段薇薇", "严家其"],
      "content": [
        {
          "type": "sound",
          "text": "BGM：甜蜜梦幻的音乐盒旋律"
        },
        {
          "type": "action",
          "text": "【中景】段薇薇兴奋地推开门——【全景·主观视角】大片粉红色扑面而来！粉色窗帘、粉色地毯、粉色墙面，沙发上放着三只半人高的粉色小熊。"
        },
        {
          "type": "dialogue",
          "character": "段薇薇",
          "emotion": "尖叫兴奋",
          "text": "天哪天哪天哪！"
        },
        {
          "type": "action",
          "text": "【中景】段薇薇直接扑向一只粉色小熊，整个人抱住——"
        },
        {
          "type": "dialogue",
          "character": "段薇薇",
          "emotion": "甜滋滋",
          "text": "这是我梦中的卧室！"
        },
        {
          "type": "action",
          "text": "【近景】龙女捂着嘴小声惊叹，严家其微笑着环顾四周。三个女生都很喜欢这样的布置。"
        },
        {
          "type": "action",
          "text": "【近景】沈央站在门口，面无表情。但镜头捕捉到——他的目光紧紧跟随着那只粉色小熊，眼底一闪而过的……是艳羡。"
        },
        {
          "type": "inner_voice",
          "character": "沈央",
          "emotion": "内心疯狂呐喊",
          "text": "超可爱！！！但是——男人不可以喜欢粉红色！是会被人耻笑的！"
        },
        {
          "type": "action",
          "text": "【特写】沈央用力抿了一下嘴唇，把嘴角压下去，恢复面无表情。但他的手指在裤缝边不自觉地蜷了蜷。"
        },
        {
          "type": "action",
          "text": "【近景】宿寒英站在沈央身后半步的位置，目光从粉色房间移到沈央微微泛红的耳尖上，嘴角几不可察地动了一下。"
        },
        {
          "type": "inner_voice",
          "character": "沈央",
          "emotion": "暗暗竖起大拇指",
          "text": "不愧是我欣赏的女孩！段薇薇品味不错！"
        },
        {
          "type": "sound",
          "text": "BGM：轻快过渡"
        },
        {
          "type": "effect",
          "text": "【快切】女生们迅速决定好上下铺位——龙女选了下铺，段薇薇选了龙女上方的上铺，严家其选了另一侧的下铺"
        }
      ]
    },
    {
      "scene_number": 2,
      "location": "小洋楼·一楼客厅",
      "time_of_day": "午后",
      "atmosphere": "轻松中暗藏尴尬，宿寒英的出手让气氛微妙升温",
      "weather": "午后暖阳",
      "sfx_ambient": "行李箱滚轮声、脚步声",
      "initial_shot": "【中景】六人回到一楼准备搬行李上楼，沈央第一个站出来",
      "characters": ["沈央", "宿寒英", "杨天驰", "段薇薇"],
      "content": [
        {
          "type": "action",
          "text": "【中景】众人回到一楼。沈央想要挽回之前的失分，第一个站起来——"
        },
        {
          "type": "dialogue",
          "character": "沈央",
          "emotion": "殷勤",
          "text": "我来帮忙搬行李吧。"
        },
        {
          "type": "inner_voice",
          "character": "沈央",
          "emotion": "暗自较劲",
          "text": "展现男友力的时候到了！挑个最大的箱子！"
        },
        {
          "type": "action",
          "text": "【中景】沈央特意走向最大的那个行李箱——恰好是段薇薇的。他弯腰，双手握住提手，用力一提——"
        },
        {
          "type": "action",
          "text": "【特写】沈央的手臂绷紧，青筋微露——箱子纹丝不动。"
        },
        {
          "type": "sound",
          "text": "音效：沉闷的'嗯——'声，像搬不动重物的闷哼"
        },
        {
          "type": "inner_voice",
          "character": "沈央",
          "emotion": "内心崩溃",
          "text": "里面装的是金砖吗？！这么沉？！"
        },
        {
          "type": "action",
          "text": "【近景】沈央的表情努力保持镇定，但额头冒出细密汗珠。他偷偷瞄了一眼镜头，心虚地又用力拉了一下——还是提不起来。"
        },
        {
          "type": "inner_voice",
          "character": "沈央",
          "emotion": "无助挣扎",
          "text": "怎么办？可以换一个箱子吗？……不行，太丢人了，在镜头面前！"
        },
        {
          "type": "action",
          "text": "【特写】沈央的手指开始发白，嘴唇紧抿，眼底浮现出绝望——"
        },
        {
          "type": "dialogue",
          "character": "宿寒英",
          "emotion": "平静低沉",
          "text": "我来。"
        },
        {
          "type": "action",
          "text": "【特写】一只修长白皙的手搭在箱子提手上，五指微凉。沈央下意识松开手，抬头——"
        },
        {
          "type": "action",
          "text": "【中景·仰拍】宿寒英面无表情，左手提起段薇薇的巨型箱子，右手顺势拎起另一只——一手一箱，步伐轻松地快步上楼。"
        },
        {
          "type": "sound",
          "text": "BGM：帅气的低音贝斯短旋律"
        },
        {
          "type": "action",
          "text": "【近景·仰拍】沈央仰头看着宿寒英一手一箱快步上楼的背影——修长的身形、黑色衬衫的肩线、毫不费力的姿态。"
        },
        {
          "type": "inner_voice",
          "character": "沈央",
          "emotion": "满怀敬意",
          "text": "社会你宿哥，人狠话不多。"
        },
        {
          "type": "action",
          "text": "【近景】沈央怔了两秒，收回目光，默默提起自己那个轻飘飘的小箱子，跟在后面上楼。"
        },
        {
          "type": "action",
          "text": "【特写】杨天驰在旁边看着这一幕，若有所思地挑了挑眉。"
        }
      ]
    },
    {
      "scene_number": 3,
      "location": "小洋楼·二楼男生卧室",
      "time_of_day": "午后",
      "atmosphere": "私密空间的微妙紧张，室友关系确立的暗藏心跳",
      "weather": "午后柔和光线",
      "sfx_ambient": "衣架碰撞声、拉链声",
      "initial_shot": "【全景】蓝色调的双人卧室，简约清爽，两张单人床对向摆放",
      "characters": ["沈央", "宿寒英", "杨天驰"],
      "content": [
        {
          "type": "action",
          "text": "【全景】三个男生来到二楼男生卧室。蓝色调的房间，两张单人床对向摆放，布置简约清爽，窗外可见院中蔷薇。"
        },
        {
          "type": "action",
          "text": "【中景】三人站在门口。三个人、两间房——怎么分？"
        },
        {
          "type": "inner_voice",
          "character": "沈央",
          "emotion": "内心盘算",
          "text": "和杨天驰住一间最没压力……他话多，不怕冷场。"
        },
        {
          "type": "action",
          "text": "【近景】沈央刚要开口，宿寒英先出声了——"
        },
        {
          "type": "dialogue",
          "character": "宿寒英",
          "emotion": "平静询问",
          "text": "你们都几点睡？"
        },
        {
          "type": "dialogue",
          "character": "沈央",
          "emotion": "老实",
          "text": "一两点。"
        },
        {
          "type": "dialogue",
          "character": "杨天驰",
          "emotion": "干脆",
          "text": "我十一点。"
        },
        {
          "type": "action",
          "text": "【近景】宿寒英转向沈央，目光直直地落在他脸上——"
        },
        {
          "type": "dialogue",
          "character": "宿寒英",
          "emotion": "语气自然但不容拒绝",
          "text": "我也睡得晚。我和你住。"
        },
        {
          "type": "sound",
          "text": "音效：轻微的心跳声，咚——只一下"
        },
        {
          "type": "action",
          "text": "【特写】沈央微微愣住，嘴唇张了一下又闭上。他没想到宿寒英会主动选自己。"
        },
        {
          "type": "dialogue",
          "character": "沈央",
          "emotion": "没有反抗精神",
          "text": "……好吧。"
        },
        {
          "type": "action",
          "text": "【近景】杨天驰的表情微妙——先是意外，然后嘴角咧开，似乎松了口气。"
        },
        {
          "type": "inner_voice",
          "character": "沈央",
          "emotion": "暗自分析",
          "text": "杨天驰好像……松了口气？也是，不用和高冷大神同住，换谁都轻松。可是——为什么选我啊？"
        },
        {
          "type": "dialogue",
          "character": "杨天驰",
          "emotion": "拍手利落",
          "text": "那就这么定了！我一个人住隔壁，你们两个别太吵啊。"
        },
        {
          "type": "action",
          "text": "【中景】杨天驰笑着拎起自己的行李走向隔壁房间。沈央和宿寒英被留在了这间蓝色的卧室里。"
        },
        {
          "type": "sound",
          "text": "BGM：轻柔的钢琴旋律缓缓浮现"
        },
        {
          "type": "effect",
          "text": "【快切蒙太奇】三楼参观——健身房、影音室、游戏厅、阳光花房的画面快速闪过。六人参观完毕回到各自房间收拾行李。"
        },
        {
          "type": "action",
          "text": "【中景】蓝色卧室内，沈央三下五除二地整理好自己那点东西，转头看——宿寒英正慢条斯理地往衣柜里挂衣服。"
        },
        {
          "type": "dialogue",
          "character": "沈央",
          "emotion": "顺口",
          "text": "要帮忙吗？"
        },
        {
          "type": "action",
          "text": "【近景】沈央以为以宿寒英的高冷会拒绝。但宿寒英转过头，嘴角微微上扬——笑了。"
        },
        {
          "type": "dialogue",
          "character": "宿寒英",
          "emotion": "温和微笑",
          "text": "谢谢。"
        },
        {
          "type": "action",
          "text": "【特写】沈央被那个笑晃了一下——宿寒英笑起来，眉眼弯弯，冷峻的五官瞬间柔和下来，好看到让人移不开目光。"
        },
        {
          "type": "inner_voice",
          "character": "沈央",
          "emotion": "恍惚",
          "text": "这人笑起来可真好看……不对，不笑的时候也很好看。一笑就是好看乘以二。"
        },
        {
          "type": "action",
          "text": "【中景】沈央拉开宿寒英的行李箱，发现衣服用几个密封袋分别装着，整整齐齐。"
        },
        {
          "type": "inner_voice",
          "character": "沈央",
          "emotion": "默默解读",
          "text": "密封袋……洁癖？龟毛？莫非还是处女座？"
        },
        {
          "type": "action",
          "text": "【特写】沈央拉开一个密封袋，翻看衣服的标签——品牌logo一闪而过，都是轻奢以上的档次。"
        },
        {
          "type": "inner_voice",
          "character": "沈央",
          "emotion": "推理中",
          "text": "最次也是轻奢……家境应该很好。"
        },
        {
          "type": "action",
          "text": "【中景】行李箱里的东西越来越少，最后只剩下一个包装精致的纸盒。沈央拿起来，翻到正面一看——"
        },
        {
          "type": "action",
          "text": "【特写】纸盒上赫然印着——四条装男士内裤。"
        },
        {
          "type": "sound",
          "text": "音效：滑稽的'叮——'声"
        },
        {
          "type": "action",
          "text": "【特写】沈央的手抖了一下，耳根迅速泛红。他手忙脚乱地想把盒子递给宿寒英——"
        },
        {
          "type": "action",
          "text": "【中景】就在两人各持内裤盒一端、尴尬交接的瞬间——"
        },
        {
          "type": "dialogue",
          "character": "沈央",
          "emotion": "慌乱",
          "text": "这个、这个你自己……"
        },
        {
          "type": "sound",
          "text": "音效：脚步声逼近，门被推开"
        },
        {
          "type": "dialogue",
          "character": "沈央",
          "emotion": "惊",
          "text": "！"
        },
        {
          "type": "action",
          "text": "【近景】导演出现在门口——那张酷似中学教导主任的脸。"
        },
        {
          "type": "dialogue",
          "character": "沈央",
          "emotion": "心虚温驯",
          "text": "……收、收拾好了。"
        },
        {
          "type": "effect",
          "text": "【定格】画面定格在沈央和宿寒英各持内裤盒一端、导演站在门口的尴尬三人构图上。字幕：「待续」"
        },
        {
          "type": "sound",
          "text": "BGM：诙谐的悬念过渡曲"
        }
      ]
    }
  ]
}