{
  "episode_number": 1,
  "title": "舞会开始",
  "scenes": [
    {
      "scene_number": 1,
      "location": "维多利亚式宴会厅·大门区域",
      "time_of_day": "未知",
      "atmosphere": "压抑诡异，暴风雨前的平静",
      "weather": "室内无窗，光线昏黄",
      "sfx_ambient": "远处传来低沉的钟声",
      "initial_shot": "【全景】封闭的维多利亚式宴会厅，黑白格地板延伸至视线尽头，四周镜子反射着昏黄灯光。四名玩家站在大厅中央，神情各异。",
      "characters": ["林异", "程思", "苏小婉", "王彪"],
      "content": [
        {
          "type": "action",
          "text": "【中景】王彪（身高185cm，体格魁梧，寸头，黑色皮夹克，左臂刀疤）大步走向大门，伸手抓住黄铜门把手用力拉扯。门纹丝不动。"
        },
        {
          "type": "dialogue",
          "character": "王彪",
          "emotion": "愤怒",
          "text": "妈的，打不开！"
        },
        {
          "type": "action",
          "text": "【特写】王彪握拳，猛力砸向大门。"
        },
        {
          "type": "sound",
          "text": "音效：沉闷的撞击声 *咚*"
        },
        {
          "type": "action",
          "text": "【全景】突然，宴会厅内响起刺耳的警报声，红色灯光闪烁。空中浮现血红色文字：'警告：禁止暴力破局，违者抹杀！'"
        },
        {
          "type": "dialogue",
          "character": "林异",
          "emotion": "冷静",
          "text": "别动。"
        },
        {
          "type": "action",
          "text": "【中景】林异（身高180cm，清瘦挺拔，黑色短发，黑色衬衫，左手腕老式机械表）站在原地，眼神冷静地扫视四周。"
        },
        {
          "type": "dialogue",
          "character": "程思",
          "emotion": "惊恐",
          "text": "这……这是什么地方？"
        },
        {
          "type": "action",
          "text": "【近景】程思（身高165cm，清秀瘦弱，棕色齐肩短发，米白色毛衣，脖子细银项链）双手抱胸，身体微微颤抖，眼神惊恐。"
        },
        {
          "type": "dialogue",
          "character": "苏小婉",
          "emotion": "虚伪笑容",
          "text": "别怕，我们一起想办法。"
        },
        {
          "type": "action",
          "text": "【中景】苏小婉（身高168cm，身材高挑，黑色长发盘成发髻，深红色丝绒长裙，右手无名指红宝石戒指）走到程思身边，露出温柔的笑容，但眼神冰冷。"
        },
        {
          "type": "sound",
          "text": "音效：优雅的华尔兹音乐骤然响起"
        },
        {
          "type": "action",
          "text": "【全景】空中再次浮现文字：'第一轮舞会开始，奏乐1分钟。所有玩家必须在白格上起舞，踏入黑格者抹杀。动作不可重复超过3秒。'"
        },
        {
          "type": "dialogue",
          "character": "林异",
          "emotion": "冷静",
          "text": "快，站到白格上！"
        },
        {
          "type": "action",
          "text": "【中景】林异快速踏上一块白色格子，转身看向其他人。程思慌乱中冲向最近的白格，差点踩到黑格边缘。"
        },
        {
          "type": "dialogue",
          "character": "程思",
          "emotion": "惊恐",
          "text": "我……我不知道怎么跳舞！"
        },
        {
          "type": "action",
          "text": "【近景】林异伸出手，眼神坚定。"
        },
        {
          "type": "dialogue",
          "character": "林异",
          "emotion": "冷静",
          "text": "跟着我，模仿我的动作。"
        },
        {
          "type": "action",
          "text": "【中景】程思握住林异的手，站在他旁边的白格上。王彪和苏小婉也各自站上白格。"
        },
        {
          "type": "action",
          "text": "【全景】音乐继续，四人开始在白格上起舞。林异动作流畅，程思笨拙地模仿。王彪动作粗暴，苏小婉优雅地旋转。"
        },
        {
          "type": "action",
          "text": "【特写】突然，一名无脸傀儡NPC从角落走出，它的身体僵硬，没有五官，只有光滑的面部。它走向王彪，开始模仿王彪的动作。"
        },
        {
          "type": "dialogue",
          "character": "王彪",
          "emotion": "惊恐",
          "text": "这什么鬼东西！"
        },
        {
          "type": "action",
          "text": "【中景】王彪加快动作，试图甩开傀儡。傀儡完美地模仿着他的每一个动作。"
        },
        {
          "type": "action",
          "text": "【近景】林异盯着傀儡，眼神一凝。他注意到傀儡的动作与王彪的动作呈镜像对称。"
        },
        {
          "type": "inner_voice",
          "character": "林异",
          "emotion": "冷静分析",
          "text": "等等……它举右手的时候，王彪举的是左手……"
        },
        {
          "type": "action",
          "text": "【全景】音乐突然停止。空中浮现文字：'静止时刻，绝对静止！'"
        },
        {
          "type": "action",
          "text": "【中景】四人瞬间停止动作，像雕塑一样僵在原地。傀儡也停止了动作，站在王彪面前。"
        },
        {
          "type": "action",
          "text": "【特写】时间一秒一秒过去。王彪额头渗出汗珠，但他不敢动。"
        },
        {
          "type": "sound",
          "text": "音效：心跳声放大 *咚咚咚*"
        },
        {
          "type": "action",
          "text": "【全景】突然，傀儡动了。它伸出手，抓住王彪的肩膀。"
        },
        {
          "type": "dialogue",
          "character": "王彪",
          "emotion": "惊恐",
          "text": "不——！"
        },
        {
          "type": "action",
          "text": "【特写】王彪的身体开始化为黑烟，从傀儡抓住的地方开始消散。"
        },
        {
          "type": "effect",
          "text": "【特效】王彪的身体化为黑烟，被傀儡吸入体内。傀儡的面部开始变化，逐渐长出王彪的五官。"
        },
        {
          "type": "action",
          "text": "【中景】程思捂住嘴，眼泪夺眶而出。"
        },
        {
          "type": "dialogue",
          "character": "程思",
          "emotion": "惊恐",
          "text": "他……他死了？"
        },
        {
          "type": "action",
          "text": "【近景】林异盯着变成王彪模样的傀儡，眼神冰冷。"
        },
        {
          "type": "dialogue",
          "character": "林异",
          "emotion": "冷静",
          "text": "不，他被替换了。"
        },
        {
          "type": "action",
          "text": "【中景】苏小婉站在一旁，嘴角微微上扬，露出一个不易察觉的笑容。"
        },
        {
          "type": "dialogue",
          "character": "苏小婉",
          "emotion": "虚伪",
          "text": "太可怕了……我们该怎么办？"
        },
        {
          "type": "action",
          "text": "【近景】林异转头看向宴会厅一侧的镜子，眼神一凝。"
        },
        {
          "type": "action",
          "text": "【特写】镜子中，林异看到自己的倒影，也看到傀儡的倒影。傀儡举起右手，而镜子中的傀儡举起的是左手。"
        },
        {
          "type": "inner_voice",
          "character": "林异",
          "emotion": "冷静",
          "text": "镜面……模仿？"
        },
        {
          "type": "action",
          "text": "【特写】林异的眼神瞬间变得锐利。"
        },
        {
          "type": "sound",
          "text": "BGM：悬疑氛围音乐渐入"
        },
        {
          "type": "action",
          "text": "【全景】画面定格在林异盯着镜子的特写上。"
        },
        {
          "type": "effect",
          "text": "【字幕】第一集完"
        }
      ]
    }
  ]
}